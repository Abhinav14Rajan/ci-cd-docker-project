pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t my-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat '''
                docker stop my-container || exit 0
                docker rm my-container || exit 0
                docker run -d -p 3000:3000 --name my-container my-app
                '''
            }
        }
    }
}